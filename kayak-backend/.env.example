# Database Configuration
DATABASE_URL=sqlite://./data/kayak.db

# JWT Configuration
# IMPORTANT: Change these in production!
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production

# Server Configuration
KAYAK__SERVER__HOST=0.0.0.0
KAYAK__SERVER__PORT=8080
KAYAK__SERVER__TIMEOUT_SECONDS=30

# Log Configuration
KAYAK__LOG__LEVEL=info
KAYAK__LOG__JSON_FORMAT=false
KAYAK__LOG__INCLUDE_LOCATION=true

# CORS Configuration
KAYAK__CORS__ALLOW_ANY_ORIGIN=true
KAYAK__CORS__MAX_AGE=3600
KAYAK__CORS__ALLOW_CREDENTIALS=false
